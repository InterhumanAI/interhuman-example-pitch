# ===========================================
# INTERHUMAN API
# ===========================================
# Create an API key at https://platform.interhuman.ai
# https://docs.interhuman.ai/how-to/get-api-key
INTERHUMAN_API_KEY=your_api_key_here

# ===========================================
# SUPABASE (Optional - for leaderboard)
# ===========================================
# The app works without Supabase, but the leaderboard won't persist.
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (for server-side operations)
# Found in Project Settings > API > service_role key (keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
