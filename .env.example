# ===========================================
# INTERHUMAN API
# ===========================================
# Get your credentials from https://interhuman.ai
# You need both the Key ID and Key Secret from your dashboard
INTERHUMAN_KEY_ID=your_key_id_here
INTERHUMAN_KEY_SECRET=your_key_secret_here

# ===========================================
# SUPABASE (Optional - for leaderboard)
# ===========================================
# The app works without Supabase, but the leaderboard won't persist.
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (for server-side operations)
# Found in Project Settings > API > service_role key (keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
