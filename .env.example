# ===========================================
# INTERHUMAN API
# ===========================================
# Create an API key at https://platform.interhuman.ai
# https://docs.interhuman.ai/how-to/get-api-key
# Use as: Authorization: Bearer <api_key>
# @see https://docs.interhuman.ai/api-reference/authentication
INTERHUMAN_API_KEY=your_api_key_here

# ===========================================
# OPENAI (Optional - for content / transcript scoring)
# ===========================================
# Enables transcribing the pitch and scoring WHAT was said (not just delivery).
# Without it, scoring gracefully falls back to delivery-only (social signals).
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ===========================================
# SUPABASE (Optional - for leaderboard)
# For Vercel / production variable names only, see .env.production.example
# ===========================================
# The app works without Supabase, but the leaderboard won't persist.
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the Project URL, publishable key, and secret key
# 4. Copy the database password from Project Settings > Database for db:setup
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_secret_key_here
SUPABASE_DB_PASSWORD=your_database_password_here

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=https://thepitchpractice.com
