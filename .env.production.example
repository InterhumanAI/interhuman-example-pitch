# Reference for production (e.g. Vercel → Settings → Environment Variables).
# Copy variable names into the host; never commit real secrets to git.

INTERHUMAN_API_KEY=

# Optional: enables content/transcript scoring. Without it, scoring falls back
# to delivery-only (social signals).
OPENAI_API_KEY=

# Leaderboard: all three must be set in Production or the API returns
# "Database not configured. Connect Supabase to enable the leaderboard."
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=

# Optional: only for applying schema from your machine (`npm run db:setup`),
# not required at runtime on Vercel.
# SUPABASE_DB_PASSWORD=
